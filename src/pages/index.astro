<script>
  // Navbar scroll
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      navbar!.style.background = '#1E3A2F';
      navbar!.style.boxShadow = '0 2px 20px rgba(0,0,0,0.25)';
    } else {
      navbar!.style.background = 'transparent';
      navbar!.style.boxShadow = 'none';
    }
  });

  // Mobile menu
  const mobileMenu = document.getElementById('mobile-menu')!;
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    mobileMenu.style.display = 'flex';
    mobileMenu.style.flexDirection = 'column';
    mobileMenu.style.alignItems = 'center';
    mobileMenu.style.justifyContent = 'center';
  });
  document.getElementById('mobile-close')?.addEventListener('click', () => {
    mobileMenu.style.display = 'none';
  });
  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => { mobileMenu.style.display = 'none'; });
  });

  // ── Quote Form ────────────────────────────────────────────────────────────

  // Multi-select steps
  const MULTI_STEPS = new Set(['1', '7', '8']);

  // Group config: step number → [groupNumber, groupLabel]
  const GROUP_MAP: Record<number, [number, string]> = {
    1: [1, 'Project Details'], 2: [1, 'Project Details'], 3: [1, 'Project Details'],
    4: [2, 'Materials & Features'], 5: [2, 'Materials & Features'], 6: [2, 'Materials & Features'],
    7: [3, 'Site & Add-Ons'], 8: [3, 'Site & Add-Ons'],
    9: [4, 'Timeline & Budget'], 10: [4, 'Timeline & Budget'],
    11: [5, 'Location & Photos'], 12: [5, 'Location & Photos'],
    13: [6, 'Contact Info'], 14: [6, 'Contact Info'],
  };
  const TOTAL_GROUPS = 6;

  // Answers store
  const multiAnswers: Record<string, string[]> = {};
  const singleAnswers: Record<string, string> = {};

  function showStep(n: number | string) {
    document.querySelectorAll('.quiz-step').forEach(el => el.classList.remove('active'));
    const target = document.querySelector(`[data-step="${n}"]`) as HTMLElement;
    if (target) target.classList.add('active');

    if (typeof n === 'number' && GROUP_MAP[n]) {
      const [groupNum, groupLabel] = GROUP_MAP[n];
      const pct = (groupNum / TOTAL_GROUPS) * 100;
      (document.getElementById('quiz-progress') as HTMLElement).style.width = `${pct}%`;
      (document.getElementById('quiz-step-label') as HTMLElement).textContent = `Step ${groupNum} of ${TOTAL_GROUPS}`;
      (document.getElementById('quiz-group-label') as HTMLElement).textContent = groupLabel;
    } else if (n === 'success' || n === 'loading') {
      (document.getElementById('quiz-progress') as HTMLElement).style.width = '100%';
      (document.getElementById('quiz-step-label') as HTMLElement).textContent = 'Done!';
      (document.getElementById('quiz-group-label') as HTMLElement).textContent = 'Complete';
    }
  }

  // Option click handlers
  document.querySelectorAll('.quiz-option').forEach(opt => {
    opt.addEventListener('click', () => {
      const step = opt.getAttribute('data-step')!;
      const value = opt.getAttribute('data-value') || '';
      const indicator = opt.querySelector('.opt-indicator') as HTMLElement;

      if (MULTI_STEPS.has(step)) {
        // Toggle for multi-select
        if (opt.classList.contains('selected')) {
          opt.classList.remove('selected');
          indicator.style.borderColor = '#D6E2D9';
          indicator.style.background = 'transparent';
          indicator.innerHTML = '';
          multiAnswers[step] = (multiAnswers[step] || []).filter(v => v !== value);
        } else {
          opt.classList.add('selected');
          indicator.style.borderColor = '#1E3A2F';
          indicator.style.background = '#1E3A2F';
          indicator.innerHTML = '<svg width="10" height="10" viewBox="0 0 12 12" fill="white"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" fill="none"/></svg>';
          multiAnswers[step] = [...(multiAnswers[step] || []), value];
        }
      } else {
        // Single select: deselect others
        document.querySelectorAll(`.quiz-option[data-step="${step}"]`).forEach(o => {
          o.classList.remove('selected');
          const ind = o.querySelector('.opt-indicator') as HTMLElement;
          if (ind) { ind.style.borderColor = '#D6E2D9'; ind.style.background = 'transparent'; }
        });
        opt.classList.add('selected');
        indicator.style.borderColor = '#1E3A2F';
        indicator.style.background = '#1E3A2F';
        singleAnswers[step] = value;
      }
    });
  });

  // Next buttons
  document.querySelectorAll('.quiz-next').forEach(btn => {
    btn.addEventListener('click', () => {
      const next = parseInt(btn.getAttribute('data-next') || '1');
      showStep(next);
    });
  });

  // Back buttons
  document.querySelectorAll('.quiz-back').forEach(btn => {
    btn.addEventListener('click', () => {
      showStep(parseInt(btn.getAttribute('data-back') || '1'));
    });
  });

  // Photo upload
  const dropZone = document.getElementById('photo-drop-zone');
  const photoInput = document.getElementById('photo-input') as HTMLInputElement;
  const previewList = document.getElementById('photo-preview-list')!;
  let selectedFiles: File[] = [];

  dropZone?.addEventListener('click', () => photoInput?.click());
  dropZone?.addEventListener('dragover', (e) => {
    e.preventDefault();
    (dropZone as HTMLElement).style.borderColor = '#C4873A';
  });
  dropZone?.addEventListener('dragleave', () => {
    (dropZone as HTMLElement).style.borderColor = '#D6E2D9';
  });
  dropZone?.addEventListener('drop', (e) => {
    e.preventDefault();
    (dropZone as HTMLElement).style.borderColor = '#D6E2D9';
    const files = Array.from((e as DragEvent).dataTransfer?.files || []).filter(f => f.type.startsWith('image/'));
    addPhotos(files);
  });
  photoInput?.addEventListener('change', () => {
    addPhotos(Array.from(photoInput.files || []));
  });

  function addPhotos(files: File[]) {
    selectedFiles = [...selectedFiles, ...files].slice(0, 10);
    previewList.innerHTML = '';
    selectedFiles.forEach((file, i) => {
      const url = URL.createObjectURL(file);
      const div = document.createElement('div');
      div.style.cssText = 'position:relative;width:64px;height:64px;border-radius:6px;overflow:hidden;border:1px solid #D6E2D9;';
      div.innerHTML = `<img src="${url}" style="width:100%;height:100%;object-fit:cover;" />
        <button type="button" data-idx="${i}" style="position:absolute;top:2px;right:2px;background:rgba(0,0,0,0.6);border:none;border-radius:50%;width:18px;height:18px;cursor:pointer;color:white;font-size:12px;line-height:1;display:flex;align-items:center;justify-content:center;">×</button>`;
      div.querySelector('button')?.addEventListener('click', (e) => {
        e.stopPropagation();
        selectedFiles.splice(i, 1);
        addPhotos([]);
      });
      previewList.appendChild(div);
    });
  }

  // Retry button
  document.getElementById('retry-btn')?.addEventListener('click', () => showStep(14));

  // Form submit
  let submitting = false;
  document.getElementById('quiz-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (submitting) return;

    const form = e.target as HTMLFormElement;

    // Validate contact fields
    const name = (form.elements.namedItem('contact_name') as HTMLInputElement).value.trim();
    const email = (form.elements.namedItem('contact_email') as HTMLInputElement).value.trim();
    const phone = (form.elements.namedItem('contact_phone') as HTMLInputElement).value.trim();
    const consent = (form.elements.namedItem('consent') as HTMLInputElement).checked;
    const city = (form.elements.namedItem('city') as HTMLInputElement).value.trim();

    if (!name || !email || !phone) {
      alert('Please fill in your name, email, and phone number.');
      return;
    }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      alert('Please enter a valid email address.');
      return;
    }
    if (!consent) {
      alert('Please check the consent box to continue.');
      return;
    }

    // Honeypot check
    const honeypot = (form.elements.namedItem('website_url') as HTMLInputElement).value;
    if (honeypot) return;

    submitting = true;
    showStep('loading');

    const payload = {
      leadSource: 'website',
      submittedAt: new Date().toISOString(),
      projectType: multiAnswers['1'] || [],
      projectSize: {
        sizeRange: singleAnswers['2'] || '',
        length: (form.elements.namedItem('dim_length') as HTMLInputElement).value,
        width: (form.elements.namedItem('dim_width') as HTMLInputElement).value,
        squareFootage: (form.elements.namedItem('dim_sqft') as HTMLInputElement).value,
      },
      deckHeight: singleAnswers['3'] || '',
      materialPreference: singleAnswers['4'] || '',
      railing: singleAnswers['5'] || '',
      stairs: singleAnswers['6'] || '',
      siteCondition: multiAnswers['7'] || [],
      addOns: multiAnswers['8'] || [],
      timeline: singleAnswers['9'] || '',
      budget: singleAnswers['10'] || '',
      location: {
        address: (form.elements.namedItem('address') as HTMLInputElement).value.trim(),
        city,
        state: (form.elements.namedItem('state') as HTMLInputElement).value.trim(),
        zip: (form.elements.namedItem('zip') as HTMLInputElement).value.trim(),
      },
      photos: selectedFiles.map(f => f.name),
      contact: { name, email, phone },
      projectNotes: (form.elements.namedItem('project_notes') as HTMLTextAreaElement).value.trim(),
      consentToContact: consent,
    };

    console.log('Grandson\'s Construction — Lead submission:', payload);

    try {
      const resp = await fetch('https://grandsons-quote-worker.jmaitner1.workers.dev/api/submit-lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (resp.ok) {
        const firstName = name.split(' ')[0];
        let data: any = {};
        try { data = await resp.json(); } catch {}
        renderSuccess(firstName, data.quote);
        showStep('success');
      } else {
        submitting = false;
        showStep('error');
      }
    } catch {
      submitting = false;
      showStep('error');
    }
  });

  // Format a dollar amount as e.g. $18,500
  function money(n: number): string {
    return '$' + Math.round(n).toLocaleString('en-US');
  }

  // Render the success screen, showing the live Claude quote when available
  function renderSuccess(firstName: string, quote: any) {
    const heading = document.getElementById('success-heading');
    const successMsg = document.getElementById('success-message');
    const card = document.getElementById('quote-card');

    if (quote && typeof quote.estimatedLow === 'number' && typeof quote.estimatedHigh === 'number') {
      if (heading) heading.textContent = `Here's your estimate, ${firstName}`;
      if (successMsg) {
        successMsg.textContent = "Based on what you shared, here's your preliminary range. We've also emailed you a copy — Richard will be in touch to confirm the details.";
      }
      const range = document.getElementById('quote-range');
      if (range) range.textContent = `${money(quote.estimatedLow)} – ${money(quote.estimatedHigh)}`;

      const conf = document.getElementById('quote-confidence');
      if (conf) {
        const label = quote.quoteConfidence ? quote.quoteConfidence.charAt(0).toUpperCase() + quote.quoteConfidence.slice(1) : '';
        conf.textContent = label ? `Confidence: ${label} — refined after a quick measurement visit` : '';
      }
      const sum = document.getElementById('quote-summary');
      if (sum) sum.textContent = quote.customerFriendlySummary || quote.projectSummary || '';

      const wrap = document.getElementById('quote-assumptions-wrap');
      const ul = document.getElementById('quote-assumptions');
      if (ul && wrap && Array.isArray(quote.assumptions) && quote.assumptions.length) {
        ul.innerHTML = '';
        quote.assumptions.forEach((a: string) => {
          const li = document.createElement('li');
          li.textContent = a;
          ul.appendChild(li);
        });
        wrap.style.display = 'block';
      }
      if (card) card.style.display = 'block';
    } else {
      // No quote returned — graceful fallback
      if (heading) heading.textContent = 'Request received!';
      if (successMsg) {
        successMsg.textContent = `Thanks, ${firstName}. We received your project details and are preparing your preliminary estimate. You'll receive an email shortly with a personalized project summary, estimated price range, key assumptions, and recommended next steps.`;
      }
      if (card) card.style.display = 'none';
    }
  }
</script>

