---
import Layout from '../layouts/Layout.astro';
---
<Layout>

<!-- NAV -->
<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 py-4 px-6 md:px-12 flex items-center justify-between" style="background: transparent;">
  <a href="#" style="display: flex; align-items: center;">
    <img src="/logo.png" alt="Grandson's Construction" id="nav-logo" style="height: 40px; width: auto; transition: filter 0.3s;" />
  </a>
  <div class="hidden md:flex items-center gap-8">
    <a href="#services" class="text-white/80 hover:text-white text-sm font-medium transition-colors" style="font-family: 'DM Sans', sans-serif;">Services</a>
    <a href="#process" class="text-white/80 hover:text-white text-sm font-medium transition-colors" style="font-family: 'DM Sans', sans-serif;">Our Process</a>
    <a href="#gallery" class="text-white/80 hover:text-white text-sm font-medium transition-colors" style="font-family: 'DM Sans', sans-serif;">Gallery</a>
    <a href="/blog" class="text-white/80 hover:text-white text-sm font-medium transition-colors" style="font-family: 'DM Sans', sans-serif;">Guides</a>
    <a href="#quiz" class="btn-primary" style="font-size: 0.875rem; padding: 0.65rem 1.25rem;">Get My Instant Estimate</a>
  </div>
  <button id="mobile-menu-btn" class="md:hidden text-white" aria-label="Menu">
    <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
  </button>
</nav>

<!-- Mobile menu -->
<div id="mobile-menu" class="fixed inset-0 z-40 flex-col items-center justify-center gap-8 text-center" style="background: #1E3A2F; display: none;">
  <img src="/logo.png" alt="Grandson's Construction" style="height: 38px; width: auto; margin-bottom: 1rem;" />
  <button id="mobile-close" class="absolute top-6 right-6 text-white">
    <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
  </button>
  <a href="#services" class="mobile-link text-white text-2xl" style="font-family: 'Playfair Display', serif;">Services</a>
  <a href="#process" class="mobile-link text-white text-2xl" style="font-family: 'Playfair Display', serif;">Our Process</a>
  <a href="#gallery" class="mobile-link text-white text-2xl" style="font-family: 'Playfair Display', serif;">Gallery</a>
  <a href="/blog" class="mobile-link text-white text-2xl" style="font-family: 'Playfair Display', serif;">Guides</a>
  <a href="#quiz" class="mobile-link btn-primary text-lg mt-4">Get My Instant Estimate</a>
</div>


<!-- HERO -->
<section class="relative flex items-center overflow-hidden" style="min-height: 100vh;">
  <div class="absolute inset-0">
    <img src="https://images.unsplash.com/photo-1558036117-15d82a90b9b1?w=1920&q=80" alt="Custom wood home with wraparound deck in West Michigan at sunset" class="w-full h-full object-cover object-center" />
    <div class="absolute inset-0" style="background: linear-gradient(105deg, rgba(20,40,25,0.85) 0%, rgba(20,40,25,0.55) 60%, rgba(0,0,0,0.15) 100%);"></div>
  </div>
  <div class="relative z-10 max-w-6xl mx-auto px-6 md:px-12" style="padding-top: 9rem; padding-bottom: 5rem;">
    <div style="max-width: 42rem;">
      <p style="color: #D9A55C; text-transform: uppercase; letter-spacing: 0.15em; font-size: 0.8rem; font-weight: 500; font-family: 'DM Sans', sans-serif; margin-bottom: 1.5rem;">West Michigan Deck Builder</p>
      <h1 class="text-white" style="font-family: 'Playfair Display', serif; font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.1; margin-bottom: 1.5rem;">
        Custom Decks<br />
        &amp; Stairs<br />
        <span style="color: #D9A55C;">in West Michigan</span>
      </h1>
      <p class="text-white/80" style="font-size: 1.1rem; line-height: 1.75; margin-bottom: 2rem; max-width: 36rem; font-family: 'DM Sans', sans-serif;">
        Custom decks, stairs, and fences for homes across Grand Rapids and West Michigan — plus other carpentry projects on request. Quality work, fair pricing, and a clear timeline from start to finish.
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: 1rem;">
        <a href="#quiz" class="btn-primary">Get My Instant Estimate →</a>
        <a href="#gallery" class="btn-outline">See Our Work</a>
      </div>
      <div style="margin-top: 3rem; display: flex; flex-wrap: wrap; gap: 1.5rem;">
        {["Real Estimate in Minutes", "No Pressure, No Obligation", "Grand Rapids & West Michigan"].map(t => (
          <span style="display: flex; align-items: center; gap: 0.5rem; color: rgba(255,255,255,0.6); font-size: 0.85rem; font-family: 'DM Sans', sans-serif;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="#D9A55C"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            {t}
          </span>
        ))}
      </div>
    </div>
  </div>
  <div class="absolute bottom-8 left-1/2" style="transform: translateX(-50%); color: rgba(255,255,255,0.4); animation: bounce 2s infinite;">
    <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M19 9l-7 7-7-7"/></svg>
  </div>
</section>


<!-- QUOTE FORM -->
<section id="quiz" style="background: #F8F4ED; padding: 6rem 1.5rem;">
  <div style="max-width: 42rem; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 2.5rem;">
      <p style="color: #C4873A; text-transform: uppercase; letter-spacing: 0.15em; font-size: 0.8rem; font-weight: 500; font-family: 'DM Sans', sans-serif; margin-bottom: 0.75rem;">Free Instant Estimate</p>
      <h2 style="font-family: 'Playfair Display', serif; font-size: clamp(2rem, 4vw, 2.75rem); color: #1E3A2F; line-height: 1.2; margin-bottom: 1rem;">
        Get your deck estimate<br /><em>in the next 2 minutes</em>
      </h2>
      <p style="color: #5a5a5a; font-family: 'DM Sans', sans-serif; font-size: 0.95rem; line-height: 1.65; max-width: 34rem; margin: 0 auto;">
        Answer a few quick questions about your project and get a real preliminary price range — instantly, on this page. No phone tag, no waiting days for a callback. The more you share, the more accurate your number.
      </p>
    </div>

    <div style="background: white; border-radius: 12px; padding: 2.5rem; box-shadow: 0 4px 24px rgba(0,0,0,0.08); border: 1px solid #EDE7D9;">

      <!-- Progress bar -->
      <div style="margin-bottom: 2rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.6rem;">
          <span id="quiz-group-label" style="font-size: 0.8rem; font-weight: 600; color: #1E3A2F; font-family: 'DM Sans', sans-serif;">Project Details</span>
          <span id="quiz-step-label" style="font-size: 0.8rem; font-weight: 500; color: #C4873A; font-family: 'DM Sans', sans-serif;">Step 1 of 6</span>
        </div>
        <div class="progress-bar">
          <div class="progress-fill" id="quiz-progress" style="width: 16.66%;"></div>
        </div>
      </div>

      <form id="quiz-form" novalidate>
        <!-- Honeypot -->
        <input type="text" name="website_url" style="position:absolute;left:-9999px;opacity:0;" tabindex="-1" autocomplete="off" />

        <!-- GROUP 1: Project Details -->

        <!-- Step 1: Project Type (multi-select) -->
        <div class="quiz-step active" data-step="1" data-group="1">
          <h3 style="font-family: 'Playfair Display', serif; font-size: 1.25rem; color: #1E3A2F; margin-bottom: 0.4rem;">What are you looking to build?</h3>
          <p style="font-size: 0.85rem; color: #5a5a5a; margin-bottom: 1.25rem; font-family: 'DM Sans', sans-serif;">Select all that apply.</p>
          <div style="display: flex; flex-direction: column; gap: 0.6rem;" id="opts-1">
            {["New deck", "Replace existing deck", "Resurface existing deck", "Stairs", "Railings", "Fence", "Deck repair", "Other project", "Not sure yet"].map(opt => (
              <div class="quiz-option multi" data-step="1" data-value={opt}>
                <div class="opt-indicator" style="width: 18px; height: 18px; border-radius: 4px; border: 2px solid #D6E2D9; flex-shrink: 0; transition: all 0.2s; display:flex; align-items:center; justify-content:center;"></div>
                <span style="font-size: 0.9rem; font-weight: 500; color: #1A1A1A; font-family: 'DM Sans', sans-serif;">{opt}</span>
              </div>
            ))}
          </div>
          <div style="margin-top: 1.5rem; display: flex; justify-content: flex-end;">
            <button type="button" class="btn-primary quiz-next" data-next="2">Next →</button>
          </div>
        </div>

        <!-- Step 2: Project Size -->
        <div class="quiz-step" data-step="2" data-group="1">
          <h3 style="font-family: 'Playfair Display', serif; font-size: 1.25rem; color: #1E3A2F; margin-bottom: 0.4rem;">How big is the project?</h3>
          <p style="font-size: 0.85rem; color: #5a5a5a; margin-bottom: 1.25rem; font-family: 'DM Sans', sans-serif;">Rough estimates are perfectly fine — we just need a ballpark.</p>
          <div style="display: flex; flex-direction: column; gap: 0.6rem;">
            {["Small (under 200 sq ft)", "Medium (200–400 sq ft)", "Large (400–600 sq ft)", "Very large (600+ sq ft)", "Not sure"].map(opt => (
              <div class="quiz-option" data-step="2" data-value={opt}>
                <div class="opt-indicator" style="width: 18px; height: 18px; border-radius: 50%; border: 2px solid #D6E2D9; flex-shrink: 0; transition: all 0.2s;"></div>
                <span style="font-size: 0.9rem; font-weight: 500; color: #1A1A1A; font-family: 'DM Sans', sans-serif;">{opt}</span>
              </div>
            ))}
          </div>
          <div style="margin-top: 1.25rem; padding: 1rem; background: #F8F4ED; border-radius: 8px; border: 1px solid #EDE7D9;">
            <p style="font-size: 0.8rem; font-weight: 600; color: #1E3A2F; margin-bottom: 0.75rem; font-family: 'DM Sans', sans-serif;">Or enter dimensions (optional):</p>
            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0.5rem;">
              <div>
                <label style="font-size: 0.75rem; color: #5a5a5a; font-family: 'DM Sans', sans-serif;">Length (ft)</label>
                <input type="number" name="dim_length" placeholder="e.g. 20" min="1" style="width: 100%; border-radius: 6px; padding: 0.5rem 0.75rem; font-size: 0.875rem; border: 1.5px solid #D6E2D9; font-family: 'DM Sans', sans-serif; box-sizing: border-box; margin-top: 0.25rem;" />
              </div>
              <div>
                <label style="font-size: 0.75rem; color: #5a5a5a; font-family: 'DM Sans', sans-serif;">Width (ft)</label>
                <input type="number" name="dim_width" placeholder="e.g. 16" min="1" style="width: 100%; border-radius: 6px; padding: 0.5rem 0.75rem; font-size: 0.875rem; border: 1.5px solid #D6E2D9; font-family: 'DM Sans', sans-serif; box-sizing: border-box; margin-top: 0.25rem;" />
              </div>
              <div>
                <label style="font-size: 0.75rem; color: #5a5a5a; font-family: 'DM Sans', sans-serif;">Sq ft</label>
                <input type="number" name="dim_sqft" placeholder="e.g. 320" min="1" style="width: 100%; border-radius: 6px; padding: 0.5rem 0.75rem; font-size: 0.875rem; border: 1.5px solid #D6E2D9; font-family: 'DM Sans', sans-serif; box-sizing: border-box; margin-top: 0.25rem;" />
              </div>
            </div>
          </div>
          <div style="margin-top: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
            <button type="button" class="quiz-back" data-back="1" style="font-size: 0.875rem; font-weight: 500; color: #5a5a5a; background: none; border: none; cursor: pointer; font-family: 'DM Sans', sans-serif;">← Back</button>
            <button type="button" class="btn-primary quiz-next" data-next="3">Next →</button>
          </div>
        </div>

        <!-- Step 3: Deck Height -->
        <div class="quiz-step" data-step="3" data-group="1">
          <h3 style="font-family: 'Playfair Display', serif; font-size: 1.25rem; color: #1E3A2F; margin-bottom: 0.4rem;">How high off the ground will the deck be?</h3>
          <p style="font-size: 0.85rem; color: #5a5a5a; margin-bottom: 1.25rem; font-family: 'DM Sans', sans-serif;">Height affects stairs, railings, footings, permits, and overall project complexity.</p>
          <div style="display: flex; flex-direction: column; gap: 0.6rem;">
            {["Ground level (0–6 inches)", "Low (6 inches – 1 ft)", "1–3 feet", "3–6 feet", "6+ feet / second-story", "Not sure"].map(opt => (
              <div class="quiz-option" data-step="3" data-value={opt}>
                <div class="opt-indicator" style="width: 18px; height: 18px; border-radius: 50%; border: 2px solid #D6E2D9; flex-shrink: 0; transition: all 0.2s;"></div>
                <span style="font-size: 0.9rem; font-weight: 500; color: #1A1A1A; font-family: 'DM Sans', sans-serif;">{opt}</span>
              </div>
            ))}
          </div>
          <div style="margin-top: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
            <button type="button" class="quiz-back" data-back="2" style="font-size: 0.875rem; font-weight: 500; color: #5a5a5a; background: none; border: none; cursor: pointer; font-family: 'DM Sans', sans-serif;">← Back</button>
            <button type="button" class="btn-primary quiz-next" data-next="4">Next →</button>
          </div>
        </div>

        <!-- GROUP 2: Materials & Features -->

        <!-- Step 4: Materials -->
        <div class="quiz-step" data-step="4" data-group="2">
          <h3 style="font-family: 'Playfair Display', serif; font-size: 1.25rem; color: #1E3A2F; margin-bottom: 0.4rem;">What material are you leaning toward?</h3>
          <p style="font-size: 0.85rem; color: #5a5a5a; margin-bottom: 1.25rem; font-family: 'DM Sans', sans-serif;">Material selection has a major impact on price, maintenance, and long-term appearance.</p>
          <div style="display: flex; flex-direction: column; gap: 0.6rem;">
            {["Pressure-treated wood (most affordable)", "Cedar (natural look, moderate price)", "Composite (low maintenance, mid-range)", "PVC / premium composite (best durability)", "Not sure — I'd like a recommendation"].map(opt => (
              <div class="quiz-option" data-step="4" data-value={opt}>
                <div class="opt-indicator" style="width: 18px; height: 18px; border-radius: 50%; border: 2px solid #D6E2D9; flex-shrink: 0; transition: all 0.2s;"></div>
                <span style="font-size: 0.9rem; font-weight: 500; color: #1A1A1A; font-family: 'DM Sans', sans-serif;">{opt}</span>
              </div>
            ))}
          </div>
          <div style="margin-top: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
            <button type="button" class="quiz-back" data-back="3" style="font-size: 0.875rem; font-weight: 500; color: #5a5a5a; background: none; border: none; cursor: pointer; font-family: 'DM Sans', sans-serif;">← Back</button>
            <button type="button" class="btn-primary quiz-next" data-next="5">Next →</button>
          </div>
        </div>

        <!-- Step 5: Railings -->
        <div class="quiz-step" data-step="5" data-group="2">
          <h3 style="font-family: 'Playfair Display', serif; font-size: 1.25rem; color: #1E3A2F; margin-bottom: 1.25rem;">What type of railing, if any?</h3>
          <div style="display: flex; flex-direction: column; gap: 0.6rem;">
            {["No railing needed", "Wood railing", "Aluminum railing", "Composite railing", "Cable railing", "Not sure"].map(opt => (
              <div class="quiz-option" data-step="5" data-value={opt}>
                <div class="opt-indicator" style="width: 18px; height: 18px; border-radius: 50%; border: 2px solid #D6E2D9; flex-shrink: 0; transition: all 0.2s;"></div>
                <span style="font-size: 0.9rem; font-weight: 500; color: #1A1A1A; font-family: 'DM Sans', sans-serif;">{opt}</span>
              </div>
            ))}
          </div>
          <div style="margin-top: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
            <button type="button" class="quiz-back" data-back="4" style="font-size: 0.875rem; font-weight: 500; color: #5a5a5a; background: none; border: none; cursor: pointer; font-family: 'DM Sans', sans-serif;">← Back</button>
            <button type="button" class="btn-primary quiz-next" data-next="6">Next →</button>
          </div>
        </div>

        <!-- Step 6: Stairs -->
        <div class="quiz-step" data-step="6" data-group="2">
          <h3 style="font-family: 'Playfair Display', serif; font-size: 1.25rem; color: #1E3A2F; margin-bottom: 1.25rem;">Will you need stairs?</h3>
          <div style="display: flex; flex-direction: column; gap: 0.6rem;">
            {["No stairs needed", "1 set of stairs", "2 or more sets of stairs", "Not sure"].map(opt => (
              <div class="quiz-option" data-step="6" data-value={opt}>
                <div class="opt-indicator" style="width: 18px; height: 18px; border-radius: 50%; border: 2px solid #D6E2D9; flex-shrink: 0; transition: all 0.2s;"></div>
                <span style="font-size: 0.9rem; font-weight: 500; color: #1A1A1A; font-family: 'DM Sans', sans-serif;">{opt}</span>
              </div>
            ))}
          </div>
          <div style="margin-top: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
            <button type="button" class="quiz-back" data-back="5" style="font-size: 0.875rem; font-weight: 500; color: #5a5a5a; background: none; border: none; cursor: pointer; font-family: 'DM Sans', sans-serif;">← Back</button>
            <button type="button" class="btn-primary quiz-next" data-next="7">Next →</button>
          </div>
        </div>

        <!-- GROUP 3: Site & Add-Ons -->

        <!-- Step 7: Site Condition (multi-select) -->
        <div class="quiz-step" data-step="7" data-group="3">
          <h3 style="font-family: 'Playfair Display', serif; font-size: 1.25rem; color: #1E3A2F; margin-bottom: 0.4rem;">What describes your site?</h3>
          <p style="font-size: 0.85rem; color: #5a5a5a; margin-bottom: 1.25rem; font-family: 'DM Sans', sans-serif;">Select all that apply.</p>
          <div style="display: flex; flex-direction: column; gap: 0.6rem;">
            {["Empty yard / new build", "Existing deck to remove", "Resurface only (no demo)", "Deck repair needed", "Sloped yard", "Limited access to backyard", "Not sure"].map(opt => (
              <div class="quiz-option multi" data-step="7" data-value={opt}>
                <div class="opt-indicator" style="width: 18px; height: 18px; border-radius: 4px; border: 2px solid #D6E2D9; flex-shrink: 0; transition: all 0.2s; display:flex; align-items:center; justify-content:center;"></div>
                <span style="font-size: 0.9rem; font-weight: 500; color: #1A1A1A; font-family: 'DM Sans', sans-serif;">{opt}</span>
              </div>
            ))}
          </div>
          <div style="margin-top: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
            <button type="button" class="quiz-back" data-back="6" style="font-size: 0.875rem; font-weight: 500; color: #5a5a5a; background: none; border: none; cursor: pointer; font-family: 'DM Sans', sans-serif;">← Back</button>
            <button type="button" class="btn-primary quiz-next" data-next="8">Next →</button>
          </div>
        </div>

        <!-- Step 8: Add-Ons (multi-select) -->
        <div class="quiz-step" data-step="8" data-group="3">
          <h3 style="font-family: 'Playfair Display', serif; font-size: 1.25rem; color: #1E3A2F; margin-bottom: 0.4rem;">Any add-on features?</h3>
          <p style="font-size: 0.85rem; color: #5a5a5a; margin-bottom: 1.25rem; font-family: 'DM Sans', sans-serif;">Select everything you're interested in — we'll talk through what makes sense.</p>
          <div style="display: flex; flex-direction: column; gap: 0.6rem;">
            {["Privacy wall or screen", "Deck lighting", "Built-in seating or benches", "Skirting / under-deck finishing", "Picture-frame border detail", "Under-deck drainage system", "Multiple levels", "Not sure yet", "None of these"].map(opt => (
              <div class="quiz-option multi" data-step="8" data-value={opt}>
                <div class="opt-indicator" style="width: 18px; height: 18px; border-radius: 4px; border: 2px solid #D6E2D9; flex-shrink: 0; transition: all 0.2s; display:flex; align-items:center; justify-content:center;"></div>
                <span style="font-size: 0.9rem; font-weight: 500; color: #1A1A1A; font-family: 'DM Sans', sans-serif;">{opt}</span>
              </div>
            ))}
          </div>
          <div style="margin-top: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
            <button type="button" class="quiz-back" data-back="7" style="font-size: 0.875rem; font-weight: 500; color: #5a5a5a; background: none; border: none; cursor: pointer; font-family: 'DM Sans', sans-serif;">← Back</button>
            <button type="button" class="btn-primary quiz-next" data-next="9">Next →</button>
          </div>
        </div>

        <!-- GROUP 4: Timeline & Budget -->

        <!-- Step 9: Timeline -->
        <div class="quiz-step" data-step="9" data-group="4">
          <h3 style="font-family: 'Playfair Display', serif; font-size: 1.25rem; color: #1E3A2F; margin-bottom: 1.25rem;">When do you want the project done?</h3>
          <div style="display: flex; flex-direction: column; gap: 0.6rem;">
            {["As soon as possible", "Within 1–3 months", "Within 3–6 months", "Sometime this year", "I'm flexible / still planning"].map(opt => (
              <div class="quiz-option" data-step="9" data-value={opt}>
                <div class="opt-indicator" style="width: 18px; height: 18px; border-radius: 50%; border: 2px solid #D6E2D9; flex-shrink: 0; transition: all 0.2s;"></div>
                <span style="font-size: 0.9rem; font-weight: 500; color: #1A1A1A; font-family: 'DM Sans', sans-serif;">{opt}</span>
              </div>
            ))}
          </div>
          <div style="margin-top: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
            <button type="button" class="quiz-back" data-back="8" style="font-size: 0.875rem; font-weight: 500; color: #5a5a5a; background: none; border: none; cursor: pointer; font-family: 'DM Sans', sans-serif;">← Back</button>
            <button type="button" class="btn-primary quiz-next" data-next="10">Next →</button>
          </div>
        </div>

        <!-- Step 10: Budget -->
        <div class="quiz-step" data-step="10" data-group="4">
          <h3 style="font-family: 'Playfair Display', serif; font-size: 1.25rem; color: #1E3A2F; margin-bottom: 0.4rem;">What's your approximate budget?</h3>
          <p style="font-size: 0.85rem; color: #5a5a5a; margin-bottom: 1.25rem; font-family: 'DM Sans', sans-serif;">Budget helps us recommend the right materials, scope, and project approach. There's no wrong answer.</p>
          <div style="display: flex; flex-direction: column; gap: 0.6rem;">
            {["Under $5,000", "$5,000 – $10,000", "$10,000 – $20,000", "$20,000 – $40,000", "$40,000+", "Not sure yet"].map(opt => (
              <div class="quiz-option" data-step="10" data-value={opt}>
