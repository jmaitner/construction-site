---
import '../styles/global.css';
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Grandson's Construction — Premium Decks & Outdoor Living | West Michigan",
  description = "West Michigan's premier deck builder. Custom decks, pergolas, stairs & outdoor living spaces built to last a lifetime. Serving Grand Rapids and within 80 miles."
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <slot />
  </body>
</html>
